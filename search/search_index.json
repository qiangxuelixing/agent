{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u5b66\u4e60agent\uff0c\u505a\u7b14\u8bb0","text":""},{"location":"rag/chunk/","title":"1. \u4e3a\u4f55\u5206\u5757","text":"<p>\u5206\u5757\u7684\u5fc5\u8981\u6027\u6e90\u81ea\u4e24\u4e2a\u6838\u5fc3\u9650\u5236\uff1a |\u9650\u5236|\u8bf4\u660e| | :--- | :--- | |\u6a21\u578b\u4e0a\u4e0b\u6587\u7a97\u53e3|LLM\u65e0\u6cd5\u4e00\u6b21\u6027\u5904\u7406\u65e0\u9650\u957f\u5ea6\u7684\u6587\u672c\uff0c\u5fc5\u987b\u5c06\u957f\u6587\u6863\u5207\u5206\u4e3a\u9002\u914d\u6a21\u578b\u5904\u7406\u80fd\u529b\u7684\u5c0f\u6587\u6863| |\u68c0\u7d22\u4fe1\u566a\u6bd4|\u82e5\u4e00\u4e2a\u6587\u672c\u5757\u5305\u542b\u8fc7\u591a\u65e0\u5173\u4fe1\u606f\uff08\u566a\u58f0\uff09\uff0c\u4f1a\u7a00\u91ca\u6838\u5fc3\u4fe1\u53f7\uff0c\u5bfc\u81f4\u68c0\u7d22\u5668\u96be\u4ee5\u7cbe\u786e\u5339\u914d\u7528\u6237\u610f\u56fe|</p>"},{"location":"rag/chunk/#2","title":"2. \u5206\u5757\u7b56\u7565","text":""},{"location":"rag/chunk/#21","title":"2.1 \u57fa\u7840\u5206\u5757\u7b56\u7565","text":""},{"location":"rag/chunk/#211","title":"2.1.1 \u56fa\u5b9a\u957f\u5ea6\u5206\u5757","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a\u6309\u56fa\u5b9a\u5b57\u7b26\u6570\u5207\u5272\u6587\u672c\uff0c\u4e0d\u8003\u8651\u8bed\u4e49\u7ed3\u6784</li> <li>\u4f18\u70b9\uff1a\u5b9e\u73b0\u7b80\u5355</li> <li>\u7f3a\u70b9\uff1a\u5bb9\u6613\u7834\u574f\u53e5\u5b50\u5b8c\u6574\u6027</li> <li>\u9002\u7528\u573a\u666f\uff1a\u975e\u7ed3\u6784\u5316\u7eaf\u6587\u672c\u9884\u5904\u7406\uff0c\u6709chunk_size\u548cchunk_overlap\u4e24\u4e2a\u503c</li> </ul>"},{"location":"rag/chunk/#212","title":"2.1.2 \u9012\u5f52\u5b57\u7b26\u5206\u5757\uff08\u63a8\u8350\uff0c\u7a33\u59a5\uff09","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a\u6309\u4f18\u5148\u7ea7\u5206\u9694\u7b26\u9012\u5f52\u5207\u5206\uff08\\n\\n -&gt; \\n -&gt; \u7a7a\u683c -&gt; \"\"\uff09\uff0c\u5c3d\u91cf\u4fdd\u7559\u6bb5\u843d\u3001\u53e5\u5b50\u5b8c\u6574\u6027\u3002</li> <li>\u9002\u7528\u573a\u666f\uff1a\u7edd\u5927\u591a\u6570\u901a\u7528\u6587\u672c\u7684\u9996\u9009\u7b56\u7565</li> </ul>"},{"location":"rag/chunk/#213","title":"2.1.3 \u57fa\u4e8e\u53e5\u5b50\u5206\u5757","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a\u4ee5\u5b8c\u6574\u53e5\u5b50\u4e3a\u5355\u4f4d\u8fdb\u884c\u7ec4\u5408\uff0c\u786e\u4fdd\u8bed\u4e49\u5b8c\u6574\uff0c\u82f1\u6587\u6587\u6863\u4e00\u822c\u662f.?  \u4e2d\u6587\u6587\u6863\u5efa\u8bae\u901a\u8fc7\u6b63\u5219\u8868\u8fbe\u5f0f\u8bc6\u522b\u3002\uff01\uff1f\u8fdb\u884c\u5207\u5206\uff0c\u6216\u4f7f\u7528spaCy\u3001HanLP\u7b49\u652f\u6301\u4e2d\u6587\u7684NLP\u5de5\u5177</li> <li>\u9002\u7528\u573a\u666f\uff1a\u6cd5\u5f8b\u6587\u4e66\u3001\u65b0\u95fb\u62a5\u9053\u3001\u5bf9\u53e5\u5b50\u5b8c\u6574\u6027\u8981\u6c42\u9ad8\u7684\u9886\u57df</li> </ul>"},{"location":"rag/chunk/#22","title":"2.2 \u7ed3\u6784\u611f\u77e5\u5206\u5757","text":"<p>\u5229\u7528\u6587\u6863\u7684\u56fa\u6709\u7ed3\u6784\uff08\u6807\u9898\u3001\u5217\u8868\u3001\u5bf9\u8bdd\u8f6e\u6b21\uff09\u4f5c\u4e3a\u5206\u5757\u8fb9\u754c\uff0c\u903b\u8f91\u66f4\u5f3a\uff0c\u4e0a\u4e0b\u6587\u66f4\u5b8c\u6574</p>"},{"location":"rag/chunk/#221","title":"2.2.1 \u7ed3\u6784\u5316\u6587\u672c\u5206\u5757","text":"<p>\u6839\u636e\u6587\u6863\u7ed3\u6784\u8fdb\u884c\u5207\u5206\uff0c\u5982md\u6587\u6863 \u4e00\u4e2a#\u662f\u4e00\u7ea7\u6807\u9898 ##\u662f\u4e8c\u7ea7\u6807\u9898 - \u6838\u5fc3\u601d\u60f3\uff1a\u6839\u636e\u6807\u9898\u5c42\u7ea7\uff08\u5982 <code>#</code>\uff0c <code>##</code>\uff09\u6216HTML\u6807\u7b7e\u5207\u5206 - \u9002\u7528\u573a\u666f\uff1a\u6280\u672f\u6587\u6863\u3001\u535a\u5ba2\u3001\u624b\u518c\u7b49\u683c\u5f0f\u89c4\u8303\u7684\u6587\u6863</p>"},{"location":"rag/chunk/#222","title":"2.2.2 \u5bf9\u8bdd\u5f0f\u5206\u5757","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a\u6309\u53d1\u8a00\u4eba\u6216\u5bf9\u8bdd\u8f6e\u6b21\u5207\u5206</li> <li>\u9002\u7528\u573a\u666f\uff1a\u5ba2\u670d\u8bb0\u5f55\u3001\u8bbf\u8c08\u3001\u4f1a\u8bae\u7eaa\u8981</li> </ul> <pre><code>\"\u5ba2\u6237\uff1a\u8fd9\u4e2a\u5546\u54c1\u591a\u653650\u5143\",\n\"\u5ba2\u670d\uff1a\u60a8\u8bf4\u7684\u662f0523\u8fd9\u4e2a\u5355\u5417\",\n\"\u5ba2\u6237\uff1a\u662f\u7684\",\n\"\u5ba2\u670d\uff1a\u597d\u7684\uff0c\u4f60\u7a0d\u7b49\u6211\u6838\u5b9e\u4e00\u4e0b\"\n</code></pre> <p>\u26a0\ufe0f\u53ef\u6269\u5c55\uff1a\u52a0\u5165\u53d1\u8a00\u4eba\u6570\u7edf\u8ba1\u3001\u60c5\u611f\u53d8\u5316\u68c0\u6d4b\u7b49\u4f5c\u4e3a\u5207\u5206\u4f9d\u636e</p>"},{"location":"rag/chunk/#23","title":"2.3 \u8bed\u4e49\u4e0e\u4e3b\u9898\u5206\u5757","text":"<p>\u8d85\u8d8a\u7269\u7406\u7ed3\u6784\uff0c\u57fa\u4e8e\u5185\u5bb9\u8bed\u4e49\u6216\u4e3b\u9898\u53d8\u5316\u8fdb\u884c\u5207\u5206</p>"},{"location":"rag/chunk/#231","title":"2.3.1 \u8bed\u4e49\u5206\u5757","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a\u8ba1\u7b97\u76f8\u90bb\u53e5\u5b50\u7684\u5411\u91cf\u76f8\u4f3c\u5ea6\uff0c\u5728\u8bed\u4e49\u7a81\u53d8\u5904\u5207\u5206</li> <li>\u9002\u7528\u573a\u666f\uff1a\u77e5\u8bc6\u5e93\u3001\u8bba\u6587\u3001\u591a\u8bdd\u9898\u6587\u6863</li> </ul> <p>\u26a0\ufe0f \u6ce8\u610f\u5411\u91cf\u76f8\u4f3c\u9608\u503c\uff0c\u8fc7\u5927\u53ef\u80fd\u5bfc\u81f4\u5f88\u96be\u5339\u914d\u76f8\u4f3c\uff0c\u6587\u6863\u5206\u5757\u8fc7\u591a\uff0c\u8fc7\u5c0f\u53ef\u80fd\u5bfc\u81f4\u76f8\u4f3c\u5ea6\u8fc7\u9ad8\uff0c\u6587\u6863\u5206\u5757\u5c11\u4e14\u5757\u6bd4\u8f83\u5927</p>"},{"location":"rag/chunk/#232","title":"2.3.2 \u57fa\u4e8e\u4e3b\u9898\u7684\u5206\u5757","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a\u662f\u7528LDA\u4e3b\u9898\u6a21\u578b\u8bc6\u522b\u6bb5\u843d\u4e3b\u9898\uff0c\u5728\u4e3b\u9898\u5207\u6362\u65f6\u5207\u5206</li> <li>\u9002\u7528\u573a\u666f\uff1a\u957f\u7bc7\u62a5\u544a\u3001\u4e66\u7c4d\u7ae0\u8282 <p>\u26a0\ufe0f \u6ce8\u610f\u4e8b\u9879 - \u4e3b\u9898\u6a21\u578b\u5bf9\u77ed\u6587\u672c\u6807\u679c\u5dee - \u9884\u5904\u7406\u5f71\u54cd\u5927\uff08\u53bb\u505c\u7528\u8bcd\u3001\u8bcd\u5e72\u8fd8\u539f\uff09 - <code>n_topics</code> \u96be\u4ee5\u9884\u4f30\uff0c\u9700\u53cd\u590d\u5b9e\u9a8c</p> </li> </ul>"},{"location":"rag/chunk/#24","title":"2.4 \u9ad8\u7ea7\u5206\u5757\u7b56\u7565","text":""},{"location":"rag/chunk/#241-","title":"2.4.1 \u5c0f-\u5927\u5206\u5757","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a</li> <li>\u5c0f\u5757\u7528\u4e8e\u68c0\u7d22\uff08\u9ad8\u7cbe\u5ea6\uff09</li> <li>\u5927\u5757\u7528\u4e8e\u751f\u6210\uff08\u4e30\u5bcc\u4e0a\u4e0b\u6587\uff09</li> <li>\u9002\u7528\u573a\u666f\uff1a\u590d\u6742\u95ee\u7b54\u7cfb\u7edf\uff0c\u9700\u517c\u987e\u68c0\u7d22\u51c6\u786e\u6027\u4e0e\u751f\u6210\u5b8c\u6574\u6027</li> </ul>"},{"location":"rag/chunk/#242","title":"2.4.2 \u4ee3\u7406\u5206\u5757","text":"<ul> <li>\u6838\u5fc3\u601d\u60f3\uff1a\u7528LLM\u6a21\u62df\u4eba\u7c7b\u9605\u8bfb\uff0c\u52a8\u6001\u8bc6\u522b\u77e5\u8bc6\u5355\u5143</li> <li>\u9002\u7528\u573a\u666f\uff1a\u5b9e\u9a8c\u6027\u9879\u76ee\u3001\u9ad8\u5ea6\u975e\u7ed3\u6784\u5316\u6587\u672c</li> </ul>"},{"location":"rag/chunk/#3","title":"3. \u6df7\u5408\u5206\u5757","text":""},{"location":"rag/chunk/#_1","title":"\u6838\u5fc3\u601d\u60f3","text":"<p>\u5148\u7528\u5b8f\u89c2\u7b56\u7565\uff08\u5982\u7ed3\u6784\u5316\u5206\u5757\uff09\u7c97\u5207\uff0c\u5728\u5bf9\u8fc7\u5927\u7684\u5757\u4f7f\u7528\u7cbe\u7ec6\u7b56\u7565\uff08\u5982\u9012\u5f52\u6216\u8bed\u4e49\u5206\u5757\uff09\u7ec6\u5207\u3002</p>"},{"location":"rag/chunk/#_2","title":"\u9002\u7528\u573a\u666f","text":"<p>\u7ed3\u6784\u590d\u6742\u3001\u5185\u5bb9\u5bc6\u5ea6\u4e0d\u5747\u7684\u6587\u6863\uff08\u5982\u6280\u672f\u767d\u76ae\u4e66\u3001\u4f01\u4e1a\u5e74\u62a5\uff09</p>"},{"location":"rag/chunk/#4","title":"4. \u5982\u4f55\u9009\u62e9\u5206\u5757\u7b56\u7565","text":""},{"location":"rag/chunk/#_3","title":"\u5206\u5c42\u51b3\u7b56\u6846\u67b6","text":"\u6b65\u9aa4 \u7b56\u7565 \u8bf4\u660e \u7b2c\u4e00\u6b65\uff1a\u57fa\u51c6\u7b56\u7565 RecurslveCharacterTextSplitter \u901a\u7528\u6027\u5f3a\uff0c\u6548\u679c\u7a33\u5b9a\uff0c\u9002\u5408\u5efa\u7acb\u6027\u80fd\u57fa\u7ebf \u7b2c\u4e8c\u6b65\uff1a\u7ed3\u6784\u4f18\u5316 MarkdownHeaderTextSplitter\u7b49 \u82e5\u6587\u6863\u6709\u7ed3\u6784\uff0c\u6709\u9650\u4f7f\u7528\u7ed3\u6784\u5316\u5206\u5757 \u7b2c\u4e09\u6b65\uff1a\u7cbe\u5ea6\u74f6\u9888 SemarticChunker\u6216ParentDocumentRetriever \u68c0\u7d22\u4e0d\u51c6\u6216\u751f\u6210\u4e0d\u5b8c\u6574\u65f6\u5f15\u5165\u8bed\u4e49/\u5c0f\u5927\u5206\u5757 \u7b2c\u56db\u6b65\uff1a\u6781\u7aef\u590d\u6742 \u6df7\u5408\u5206\u5757 \u591a\u683c\u5f0f\u3001\u957f\u6587\u672c\u3001\u9ad8\u5bc6\u5ea6\u573a\u666f\u7684\u7ec8\u6781\u65b9\u6848"},{"location":"rag/chunk/#_4","title":"\u5206\u5757\u7b56\u7565\u5bf9\u6bd4\u8868","text":"\u7b56\u7565 \u8bed\u4e49\u5b8c\u6574\u6027 \u5b9e\u73b0\u96be\u5ea6 \u9002\u7528\u573a\u666f \u662f\u5426\u63a8\u8350 \u56fa\u5b9a\u957f\u5ea6\u5206\u5757 \u2605\u2606\u2606\u2606\u2606 \u2605\u2606\u2606\u2606\u2606 \u7eaf\u6587\u672c\u9884\u5904\u7406 \u274c \u9012\u5f52\u5b57\u7b26\u5206\u5757 \u2605\u2605\u2605\u2606\u2606 \u2605\u2606\u2606\u2606\u2606 \u901a\u7528\u6587\u672c\uff08\u63a8\u8350\u8d77\u70b9\uff09 \u2705\u2705\u2705 \u53e5\u5b50\u5206\u5757 \u2605\u2605\u2605\u2605\u2606 \u2605\u2605\u2606\u2606\u2606 \u6cd5\u5f8b\u3001\u65b0\u95fb\u7b49 \u2705 \u7ed3\u6784\u5316\u5206\u5757 \u2605\u2605\u2605\u2605\u2606 \u2605\u2605\u2606\u2606\u2606 Mrakdown/HTML\u6587\u6863 \u2705\u2705 \u5bf9\u8bdd\u5206\u5757 \u2605\u2605\u2605\u2605\u2606 \u2605\u2606\u2606\u2606\u2606 \u5ba2\u670d\u3001\u4f1a\u8bae\u8bb0\u5f55 \u2705 \u8bed\u4e49\u5206\u5757 \u2605\u2605\u2605\u2605\u2605 \u2605\u2605\u2605\u2605\u2606 \u9ad8\u7cbe\u5ea6\u77e5\u8bc6\u5e93 \u2705\uff08\u8fdb\u9636\uff09 \u4e3b\u9898\u5206\u5757\uff08LDA\uff09 \u2605\u2605\u2605\u2606\u2606 \u2605\u2605\u2605\u2605\u2606 \u591a\u4e3b\u9898\u957f\u6587 \u26a0\ufe0f\uff08\u5b9e\u9a8c\u6027\uff09 \u5c0f-\u5927\u5206\u5757 \u2605\u2605\u2605\u2605\u2606 \u2605\u2605\u2605\u2606\u2606 \u590d\u6742\u95ee\u7b54\u7cfb\u7edf \u2705\u2705 \u4ee3\u7406\u5f0f\u5206\u5757 \u2605\u2605\u2605\u2605\u2605 \u2605\u2605\u2605\u2605\u2605 \u9ad8\u4ef7\u503c\u77e5\u8bc6\u5efa\u6a21 \ud83d\udd2c\uff08\u7814\u7a76\u5411\uff09 \u6df7\u5408\u5206\u5757 \u2605\u2605\u2605\u2605\u2606 \u2605\u2605\u2605\u2606\u2606 \u590d\u6742\u6587\u6863 \u2705\u2705\u2705\uff08\u751f\u4ea7\u63a8\u8350\uff09"},{"location":"rag/chunk/#4_1","title":"4. \u7ed3\u8bba\uff1a\u5206\u5757\u662f\u5b9e\u8df5\uff0c\u800c\u975e\u7406\u8bba","text":""},{"location":"rag/chunk/#_5","title":"\u6838\u5fc3\u8ba4\u77e5","text":"<ol> <li>\u6ca1\u6709\u94f6\u5f39    \u6ca1\u6709\u4efb\u4f55\u4e00\u79cd\u65b9\u6cd5\u9002\u7528\u4e8e\u6240\u6709\u573a\u666f\uff0c\u5fc5\u987b\u6839\u636e\u6570\u636e\u7279\u5f81\u3001\u4e1a\u52a1\u9700\u6c42\u6301\u7eed\u8fed\u4ee3\u4f18\u5316\u3002</li> <li>\u59cb\u4e8e\u7b80\u5355\uff0c\u7ec8\u4e8e\u590d\u5408    \u4ece <code>RecursiveCharacterTextSplitter</code> \u5efa\u7acb\u57fa\u7ebf\uff0c\u9010\u6b65\u5f15\u5165\u7ed3\u6784\u5316\u3001\u8bed\u4e49\u5316\u3001\u6df7\u5408\u7b56\u7565\uff0c\u662f\u6700\u7a33\u5065\u7684\u8def\u5f84\u3002</li> <li>\u5206\u5757\u5373\u5efa\u6a21    \u4f60\u600e\u4e48\u5207\u6587\u6863\uff0c\u5c31\u7b49\u4e8e\u4f60\u600e\u4e48\u7406\u89e3\u77e5\u8bc6\uff0c\u9ad8\u8d28\u91cf\u7684\u5206\u5757\u672c\u8eab\u5c31\u662f\u4e00\u79cd\u8bed\u4e49\u589e\u5f3a\u4e0e\u7ed3\u6784\u5316\u7684\u8fc7\u7a0b\u3002 <p>\ud83c\udf1f\u6700\u7ec8\u5efa\u8bae \u628a\u5206\u5757\u5f53\u6210\u4e00\u4e2a\u53ef\u5ea6\u91cf\u3001\u53ef\u5b9e\u9a8c\u3001\u53ef\u4f18\u5316\u7684\u5de5\u7a0b\u6a21\u5757\uff0c\u7ed3\u5408\u8bc4\u4f30\u6307\u6807\uff08\u5982\u68c0\u7d22\u547d\u4e2d\u7387\u3001\u7b54\u6848\u51c6\u786e\u7387\uff09\u8fdb\u884cA/B\u5b9e\u9a8c\uff0c\u624d\u80fd\u771f\u6b63\u53d1\u6325\u5176\u4ef7\u503c</p> </li> </ol> <p>\ud83d\udccc \u9644\u5f55\uff1a\u5b9e\u7528\u5efa\u8bae\u6e05\u5355 - \u2705 \u4f18\u5148\u5b9e\u7528 <code>RecursiveCharacterTextSplitter</code> \u4f5c\u4e3a\u57fa\u51c6\u3002 - \u2705 \u5904\u7406\u4e2d\u6587\u65f6\u6ce8\u610f\u5206\u53e5\u5de5\u5177\u7684\u9009\u62e9\uff08\u907f\u514d\u76f4\u63a5\u4f7f\u7528\u82f1\u6587Punkt\uff09 - \u2705 \u5408\u7406\u8bbe\u503c <code>chunk_overlap</code> \uff08\u5efa\u8bae10%-20%\uff09 - \u2705 \u5bf9\u957f\u6587\u6863\u5c1d\u8bd5\u6df7\u5408\u7b56\u7565 - \u2705 \u8bed\u4e49\u5206\u5757\u9700\u8c03\u6574\uff0c\u5efa\u8bae\u4ece <code>percentile=70</code> \u5f00\u59cb - \u2705 \u5c0f-\u5927\u5206\u5757\u9002\u5408\u9ad8\u8981\u6c42\u95ee\u7b54\u7cfb\u7edf - \u2705 \u4ee3\u7406\u5f0f\u5206\u5757\u5c1a\u5904\u4e8e\u5b9e\u9a8c\u9636\u6bb5\uff0c\u8c28\u614e\u7528\u4e8e\u751f\u4ea7</p>"}]}